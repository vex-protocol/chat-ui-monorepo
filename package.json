{
    "name": "vex-chat",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm -r --parallel dev",
        "prepare": "husky",
        "registry": "npx verdaccio -c .verdaccio/config.yaml",
        "publish:local": "./scripts/publish-local.sh",
        "install:local": "./scripts/install-local.sh",
        "build": "pnpm -r --if-present build",
        "test": "pnpm -r --if-present test",
        "typecheck": "pnpm -r --if-present typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "pnpm -r --if-present lint",
        "lint:fix": "pnpm -r --if-present lint:fix",
        "lint:pkg": "pnpm dlx npm-package-json-lint .",
        "license:check": "pnpm -r --if-present license:check",
        "mobile": "pnpm -F mobile dev",
        "android:dev": "pnpm -F mobile run android:dev",
        "android:dev:install": "pnpm -F mobile run android:dev:install",
        "android:prod": "pnpm -F mobile run android:prod",
        "android:prod:install": "pnpm -F mobile run android:prod:install",
        "android:reset-db": "pnpm -F mobile run android:reset-db",
        "android:staging": "pnpm run android:dev",
        "install:android": "pnpm -F mobile run android:release:install-all",
        "install:ios": "pnpm -F mobile run ios:release:install",
        "preinstall": "npx only-allow pnpm"
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10.0.0"
    },
    "devDependencies": {
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.2.0",
        "prettier-plugin-svelte": "^3.5.1",
        "typescript": "catalog:",
        "typescript-eslint": "^8.32.1"
    },
    "pnpm": {
        "overrides": {
            "react": "19.2.0",
            "react-dom": "19.2.0",
            "kysely": "0.28.17",
            "typescript": "~5.9.3",
            "svelte@<4.2.19": ">=4.2.19",
            "esbuild@<=0.24.2": ">=0.25.0",
            "svelte@<=5.51.4": ">=5.51.5",
            "svelte@<=5.53.4": ">=5.53.5",
            "svelte@<=5.55.6": ">=5.55.7",
            "devalue@>=5.6.3 <=5.8.0": ">=5.8.1",
            "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
            "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
            "follow-redirects@<=1.15.11": ">=1.16.0",
            "dompurify@<=3.3.3": ">=3.4.0",
            "fast-xml-parser@<5.7.0": ">=5.7.0",
            "@xmldom/xmldom": "0.8.13",
            "postcss@<8.5.10": ">=8.5.10",
            "dompurify@<3.4.0": ">=3.4.0",
            "dompurify@>=1.0.10 <3.4.0": ">=3.4.0",
            "dompurify@>=3.0.1 <3.4.0": ">=3.4.0",
            "fast-xml-builder@<=1.1.6": "1.1.7",
            "uuid@>=11.0.0 <11.1.1": ">=11.1.1",
            "@angular/compiler@<=18.2.14": "19.2.21",
            "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
            "ws@>=8.0.0 <8.20.1": "8.20.1"
        },
        "peerDependencyRules": {
            "allowedVersions": {
                "expo-sqlite": ">=16",
                "typescript": ">=5",
                "@sveltejs/vite-plugin-svelte": ">=2"
            }
        },
        "onlyBuiltDependencies": [
            "sharp",
            "better-sqlite3",
            "esbuild",
            "msgpackr-extract"
        ]
    },
    "license": "AGPL-3.0-or-later"
}
