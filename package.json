{
    "name": "vex-chat",
    "version": "1.2.0-rc.7",
    "private": "true",
    "type": "module",
    "scripts": {
        "dev": "pnpm -r --parallel dev",
        "prepare": "husky",
        "registry": "npx verdaccio -c .verdaccio/config.yaml",
        "publish:local": "./scripts/publish-local.sh",
        "install:local": "./scripts/install-local.sh",
        "build": "pnpm -r --if-present build",
        "test": "pnpm -r --if-present test",
        "typecheck": "pnpm -r --if-present typecheck",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "pnpm -r --if-present lint",
        "lint:fix": "pnpm -r --if-present lint:fix",
        "lint:pkg": "pnpm dlx npm-package-json-lint .",
        "license:check": "pnpm -r --if-present license:check",
        "preinstall": "npx only-allow pnpm"
    },
    "packageManager": "pnpm@10.30.3",
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10.0.0"
    },
    "devDependencies": {
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "prettier": "^3.2.0",
        "typescript": "catalog:",
        "typescript-eslint": "^8.32.1"
    },
    "pnpm": {
        "overrides": {
            "react": "19.2.0"
        },
        "peerDependencyRules": {
            "allowedVersions": {
                "expo-sqlite": ">=16",
                "typescript": ">=5",
                "@sveltejs/vite-plugin-svelte": ">=2"
            }
        },
        "onlyBuiltDependencies": [
            "sharp",
            "better-sqlite3",
            "esbuild",
            "msgpackr-extract"
        ]
    },
    "license": "AGPL-3.0-or-later"
}
