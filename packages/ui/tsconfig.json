{
    "compilerOptions": {
        "jsx": "preserve",
        "jsxImportSource": "@builder.io/mitosis",
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": true
    },
    "include": ["src", "scripts"]
}
