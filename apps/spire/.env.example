# ─── Database ────────────────────────────────────────────────────────────────
# "sqlite" for local development; "postgres" for production
DB_TYPE=sqlite

# SQLite only — path to the database file (omit to use ./spire.db)
# SQLITE_PATH=spire.db

# Postgres only — required when DB_TYPE=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/spire

# ─── Cryptographic secrets ────────────────────────────────────────────────────
# NaCl Ed25519 server signing key (hex-encoded 64-byte private key).
# Generate with: node -e "import('tweetnacl').then(m=>console.log(Buffer.from(m.default.sign.keyPair().secretKey).toString('hex')))"
# Or run: pnpm --filter spire setup
SPK=

# JWT HMAC secret — must be at least 32 chars. Keep separate from SPK.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or run: pnpm --filter spire setup
JWT_SECRET=

# ─── Server ───────────────────────────────────────────────────────────────────
API_PORT=16777

# ─── Logging ──────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error
LOG_LEVEL=info
NODE_ENV=development
