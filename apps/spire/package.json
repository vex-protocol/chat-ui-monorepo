{
  "name": "@vex-chat/spire",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#db/*": "./src/db/*.js",
    "#auth/*": "./src/auth/*.js",
    "#devices/*": "./src/devices/*.js",
    "#utils/*": "./src/utils/*.js",
    "#config": "./src/config.js",
    "#openapi": "./src/openapi.js",
    "#errors": "./src/errors.js",
    "#test/*": "./test/*.js"
  },
  "scripts": {
    "dev": "node --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:openapi": "node --import tsx/esm scripts/generate-openapi.ts"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "better-sqlite3": "catalog:",
    "express": "^5.2.1",
    "jose": "^5.0.0",
    "kysely": "^0.27.0",
    "pino": "^10.3.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "pino-pretty": "^13.1.3",
    "@types/better-sqlite3": "catalog:",
    "@types/express": "^5.0.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
