{
  "name": "@vex-chat/spire",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#db/*": "./src/db/*.js",
    "#auth/*": "./src/auth/*.js",
    "#devices/*": "./src/devices/*.js",
    "#keys/*": "./src/keys/*.js",
    "#ws/*": "./src/ws/*.js",
    "#mail/*": "./src/mail/*.js",
    "#servers/*": "./src/servers/*.js",
    "#permissions/*": "./src/permissions/*.js",
    "#invites/*": "./src/invites/*.js",
    "#files/*": "./src/files/*.js",
    "#utils/*": "./src/utils/*.js",
    "#config": "./src/config.js",
    "#openapi": "./src/openapi.js",
    "#errors": "./src/errors.js",
    "#test/*": "./test/*.js"
  },
  "scripts": {
    "start": "node dist/run.js",
    "build": "pnpm generate:openapi && tsc -p tsconfig.build.json",
    "dev": "node --watch --import tsx/esm src/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:openapi": "node --import tsx/esm scripts/generate-openapi.ts",
    "lint:openapi": "spectral lint openapi.json"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "argon2": "^0.44.0",
    "better-sqlite3": "catalog:",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jose": "^5.0.0",
    "kysely": "^0.27.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "catalog:",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "catalog:",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
