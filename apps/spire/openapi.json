    "/register": {
      "post": {
        "operationId": "register",
        "responses": {
          "200": {
            "description": "User created"
          },
          "409": {
            "description": "Username taken"
          }
        }
      }
    },
    "/auth": {
      "post": {
        "operationId": "login",
        "responses": {
          "200": {
            "description": "JWT issued"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/whoami": {
      "post": {
        "operationId": "whoami",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated user"
          },
          "401": {
            "description": "Unauthorized"
          }
