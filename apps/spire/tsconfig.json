{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["esnext"],
    "types": ["node", "express"],
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "#db/*": ["./src/db/*"],
      "#auth/*": ["./src/auth/*"],
      "#devices/*": ["./src/devices/*"],
      "#keys/*": ["./src/keys/*"],
      "#ws/*": ["./src/ws/*"],
      "#utils/*": ["./src/utils/*"],
      "#config": ["./src/config.js"],
      "#openapi": ["./src/openapi.js"],
      "#errors": ["./src/errors.js"],
      "#test/*": ["./test/*"]
    }
  },
  "include": ["src", "test"]
}
