# apps/mobile environment variables (example — copy to .env.local to use)
#
# .env.local is gitignored. .env.example is the only committed env file and
# exists purely to document available overrides. Production builds default
# to api.vex.wtf with NO .env involvement — the prod URL is a typed constant
# in src/lib/config.ts and cannot be changed via environment.
#
# Override only for local development, e.g. (must also set EXPO_PUBLIC_ENABLE_DEV_SERVER=1):
#   - iOS simulator:   EXPO_PUBLIC_SERVER_URL=localhost:16777
#   - Android emu:     EXPO_PUBLIC_SERVER_URL=localhost:16777  (with `adb reverse tcp:16777 tcp:16777`)
#   - LAN device:      EXPO_PUBLIC_SERVER_URL=192.168.x.x:16777
#   - Tailscale/off-LAN: EXPO_PUBLIC_SERVER_URL=100.x.y.z:16777
#
# Release builds throw at startup if this resolves to a dev host.
EXPO_PUBLIC_ENABLE_DEV_SERVER=
EXPO_PUBLIC_SERVER_URL=
