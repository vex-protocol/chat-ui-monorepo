{
    "name": "@vex-chat/mobile",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "android:clean-autolinking": "node -e \"require('node:fs').rmSync('android/build/generated/autolinking', { recursive: true, force: true })\"",
        "android": "pnpm run android:clean-autolinking && bash ./scripts/run-with-android-jdk.sh bash ./scripts/android-run.sh",
        "android:multi": "bash ./scripts/run-with-android-jdk.sh bash ./scripts/android-with-logs.sh",
        "android:emulator": "bash ./scripts/run-with-android-jdk.sh bash ./scripts/start-android-emulator.sh",
        "android:release:install-all": "bash ./scripts/release-apk-install-all.sh",
        "ios:release:install": "bash ./scripts/install-ios-release.sh",
        "ios": "expo run:ios",
        "dev": "pnpm run android:multi",
        "dev:metro": "expo start --dev-client",
        "dev:local": "EXPO_PUBLIC_ENABLE_DEV_SERVER=1 EXPO_PUBLIC_SERVER_URL=localhost:16777 expo start --dev-client",
        "dev:lan": "EXPO_PUBLIC_ENABLE_DEV_SERVER=1 EXPO_PUBLIC_SERVER_URL=$(ipconfig getifaddr en0):16777 expo start --dev-client",
        "dev:android-reverse": "adb reverse tcp:16777 tcp:16777 && EXPO_PUBLIC_ENABLE_DEV_SERVER=1 EXPO_PUBLIC_SERVER_URL=localhost:16777 expo start --dev-client",
        "prebuild": "expo prebuild --clean",
        "start": "expo start",
        "logs:android:all": "bash ./scripts/logcat-all-devices.sh",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "license:check": "npx @onebeyond/license-checker scan --allowOnly MIT ISC BSD-2-Clause BSD-3-Clause Apache-2.0 0BSD MPL-2.0 CC0-1.0 CC-BY-4.0 Unlicense BlueOak-1.0.0 Python-2.0 Zlib PSF-2.0 Artistic-2.0 AGPL-3.0-or-later WTFPL --ignoreRootPackageLicense --disableReport"
    },
    "dependencies": {
        "@nanostores/react": "catalog:",
        "@notifee/react-native": "catalog:",
        "@react-navigation/bottom-tabs": "^7.3.0",
        "@react-navigation/native": "^7.1.0",
        "@react-navigation/native-stack": "^7.3.0",
        "@vex-chat/store": "workspace:*",
        "expo": "^55.0.13",
        "expo-background-fetch": "catalog:",
        "expo-background-task": "catalog:",
        "expo-clipboard": "catalog:",
        "expo-document-picker": "catalog:",
        "expo-file-system": "catalog:",
        "expo-haptics": "~55.0.7",
        "expo-image-manipulator": "catalog:",
        "expo-image-picker": "^55.0.18",
        "expo-notifications": "~55.0.18",
        "expo-secure-store": "^55.0.13",
        "expo-sharing": "catalog:",
        "expo-sqlite": "^55.0.15",
        "expo-task-manager": "catalog:",
        "expo-updates": "~55.0.0",
        "kysely": "catalog:",
        "kysely-expo": "^5.0.0",
        "nanostores": "catalog:",
        "react": "catalog:",
        "react-native": "0.83.4",
        "react-native-get-random-values": "^1.11.0",
        "react-native-logs": "^5.6.0",
        "react-native-passkey": "catalog:",
        "react-native-safe-area-context": "5.6.2",
        "react-native-screens": "4.23.0",
        "react-native-svg": "^15.15.3",
        "uuid": "catalog:"
    },
    "devDependencies": {
        "@babel/core": "^7.25.2",
        "@types/react": "^19.2.0",
        "@vex-chat/eslint-config": "workspace:*",
        "@vex-chat/libvex": "catalog:",
        "babel-preset-expo": "^55.0.15",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "typescript": "catalog:"
    },
    "engines": {
        "node": ">= 22.11.0"
    },
    "license": "AGPL-3.0-or-later"
}
